# Environment Configuration for Clinerva Backend

# Application Settings
NODE_ENV=development
PORT=5001

# MongoDB Configuration
# For local development:
# MONGODB_URI=mongodb://localhost:27017/clinerva

# For MongoDB Atlas (Cloud):
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/clinerva?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_12345
JWT_EXPIRE=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# API Keys (if needed for external services)
# SENDGRID_API_KEY=your_sendgrid_key
# AWS_ACCESS_KEY_ID=your_aws_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Logging
LOG_LEVEL=debug
LOG_FILE=./logs/app.log

# Feature Flags
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_AI_MATCHING=true
ENABLE_ANALYTICS=true

# Cloudinary Configuration (for image uploads)
CLOUDINARY_CLOUD_NAME=dua90mpb2
CLOUDINARY_API_KEY=321418513936918
CLOUDINARY_API_SECRET=w-LtAG7YSzPeKCuvbv9pmKD8tcA

# Bytez.js Configuration (for AI matching with GPT-4o)
BYTEZ_API_KEY=your_bytez_api_key_here
BYTEZ_MODEL=openai/gpt-4o
BYTEZ_ENABLED=true

# AI Matching Settings
AI_MATCHING_CONFIDENCE_THRESHOLD=0.7
AI_MATCH_EXPLANATION_ENABLED=true
