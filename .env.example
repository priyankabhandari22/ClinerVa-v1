# Clinerva — Python AI Engine (.env.example)
# Do NOT commit real secrets. Copy to `.env` locally and fill values.

# Google Gemini API Key (used by gemini_parser.py)
GEMINI_API_KEY=your_google_gemini_api_key_here

# Optional runtime settings
# Render provides `PORT` automatically; include only for local runs
PORT=8000
LOG_LEVEL=info